# 复制为 .env 并填入自己的 key（.env 已被 git 忽略）
# 商品评价检索（稳定来源）：https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# 底层文本 LLM（OpenAI 兼容接口；DeepSeek / 通义 / 其它中转皆可）。
# base 含 /v1 时自动只补 /chat/completions，例如通义：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  +  LLM_MODEL=qwen3.7-plus
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 截图识别（多模态视觉，OpenAI 兼容）。不填则截图功能不可用，仅链接/文本识别。
# 需用「能识图」的模型：通义 qwen3.7-plus（旗舰多模态）/ qwen3-vl-plus / qwen-vl-max 等。
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.7-plus

# 可选：直连 Anthropic Claude（不填则用上面的 LLM）
# ANTHROPIC_API_KEY=
